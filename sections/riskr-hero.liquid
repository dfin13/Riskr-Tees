<div class="riskr-hero" id="riskr-hero">
  <div class="riskr-hero__inner page-width">

    <div class="riskr-hero__content">
      <p class="riskr-hero__eyebrow">Riskr&trade; &mdash; A Human Capital Initiative</p>

      <h1 class="riskr-hero__wordmark">RISKR</h1>

      <p class="riskr-hero__tagline">
        Apparel engineered to signal ambition,<br>
        communicate alignment, and facilitate synergy.
      </p>

      <div class="riskr-hero__actions">
        <a href="{{ routes.collections_url }}/all" class="riskr-hero__cta riskr-hero__cta--primary">
          Shop the Collection
        </a>
        <a href="#riskr-mission" class="riskr-hero__cta riskr-hero__cta--secondary">
          Our Mission &darr;
        </a>
      </div>
    </div>

  </div>
</div>

<style>
  .riskr-hero {
    background: #000;
    width: 100%;
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    position: relative;
    overflow: hidden;
  }

  .riskr-hero__inner {
    padding-block: 0 56px;
    width: 100%;
  }

  .riskr-hero__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
    max-width: 900px;
  }

  .riskr-hero__eyebrow {
    color: rgba(255, 255, 255, 0.38);
    font-family: var(--font-body--family);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin: 0 0 24px;
  }

  .riskr-hero__wordmark {
    color: #fff;
    font-family: var(--font-heading--family);
    font-size: clamp(88px, 14vw, 192px);
    font-weight: 700;
    line-height: 0.86;
    letter-spacing: -0.05em;
    margin: 0 0 40px;
    text-transform: uppercase;
  }

  .riskr-hero__tagline {
    color: rgba(255, 255, 255, 0.52);
    font-family: var(--font-body--family);
    font-size: clamp(14px, 1.5vw, 18px);
    font-weight: 400;
    line-height: 1.6;
    margin: 0 0 48px;
    max-width: 440px;
  }

  .riskr-hero__actions {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .riskr-hero__cta {
    display: inline-block;
    font-family: var(--font-body--family);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-decoration: none;
    padding: 15px 26px;
    border-radius: 0;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
    white-space: nowrap;
  }

  .riskr-hero__cta--primary {
    background: #fff;
    color: #000;
    border: 1px solid #fff;
  }

  .riskr-hero__cta--primary:hover {
    background: #d8d8d8;
    border-color: #d8d8d8;
  }

  .riskr-hero__cta--secondary {
    background: transparent;
    color: rgba(255, 255, 255, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.22);
  }

  .riskr-hero__cta--secondary:hover {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.5);
  }

  @media (prefers-reduced-motion: no-preference) {
    @keyframes riskr-fade-up {
      from { opacity: 0; transform: translateY(14px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .riskr-hero__eyebrow {
      opacity: 0;
      animation: riskr-fade-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.15s forwards;
    }
    .riskr-hero__wordmark {
      opacity: 0;
      animation: riskr-fade-up 0.85s cubic-bezier(0.16, 1, 0.3, 1) 0.26s forwards;
    }
    .riskr-hero__tagline {
      opacity: 0;
      animation: riskr-fade-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.44s forwards;
    }
    .riskr-hero__actions {
      opacity: 0;
      animation: riskr-fade-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.58s forwards;
    }
  }

  @media screen and (max-width: 749px) {
    .riskr-hero {
      min-height: 100svh;
      align-items: flex-end;
    }

    .riskr-hero__inner {
      padding-block: 0 40px;
    }

    .riskr-hero__wordmark {
      margin-bottom: 28px;
    }

    .riskr-hero__tagline {
      max-width: 100%;
      margin-bottom: 36px;
    }

    .riskr-hero__actions {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }

    .riskr-hero__cta {
      width: 100%;
      text-align: center;
    }
  }
</style>

{% schema %}
{
  "name": "Riskr Hero",
  "tag": "section",
  "class": "riskr-hero-section",
  "settings": [],
  "presets": [
    {
      "name": "Riskr Hero"
    }
  ]
}
{% endschema %}
