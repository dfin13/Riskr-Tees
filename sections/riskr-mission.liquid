<div class="riskr-mission" id="riskr-mission">
  <div class="riskr-mission__inner page-width">

    <div class="riskr-mission__col-label">
      <span class="riskr-mission__label">Our Mission</span>
    </div>

    <div class="riskr-mission__col-body">
      <h2 class="riskr-mission__headline">
        Driving Impact at Scale.<br>
        One Shirt at a Time.
      </h2>

      <div class="riskr-mission__copy">
        <p>
          At Riskr, we believe meaningful disruption begins with what you wear to the all-hands.
        </p>
        <p>
          Our garments are engineered to communicate alignment, signal bandwidth, and facilitate the kind of low-friction stakeholder engagement that moves the needle on cross-functional deliverables.
        </p>
        <p>
          This is not a clothing company.<br>
          This is a human capital optimization platform that happens to sell shirts.
        </p>
      </div>

      <a href="{{ routes.collections_url }}/all" class="riskr-mission__link">
        View all products <span class="riskr-mission__link-arrow">&rarr;</span>
      </a>
    </div>

  </div>
</div>

<style>
  .riskr-mission {
    background: #fff;
    padding-block: 112px;
    border-top: 1px solid #e8e8e8;
  }

  .riskr-mission__inner {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 0 80px;
    align-items: start;
  }

  .riskr-mission__col-label {
    padding-top: 10px;
  }

  .riskr-mission__label {
    display: block;
    font-family: var(--font-body--family);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(0, 0, 0, 0.38);
  }

  .riskr-mission__headline {
    font-family: var(--font-heading--family);
    font-size: clamp(36px, 5.5vw, 72px);
    font-weight: 700;
    line-height: 1.02;
    letter-spacing: -0.025em;
    color: #000;
    margin: 0 0 40px;
  }

  .riskr-mission__copy {
    margin-bottom: 40px;
  }

  .riskr-mission__copy p {
    font-family: var(--font-body--family);
    font-size: 0.9375rem;
    font-weight: 400;
    line-height: 1.7;
    color: rgba(0, 0, 0, 0.6);
    margin: 0 0 20px;
    max-width: 560px;
  }

  .riskr-mission__copy p:last-child {
    margin-bottom: 0;
  }

  .riskr-mission__link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-body--family);
    font-size: 0.875rem;
    font-weight: 500;
    color: #000;
    text-decoration: none;
    letter-spacing: 0.01em;
    border-bottom: 1px solid #000;
    padding-block: 6px 2px;
  }

  .riskr-mission__link-arrow {
    display: inline-block;
    transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .riskr-mission__link:hover .riskr-mission__link-arrow {
    transform: translateX(5px);
  }

  @media screen and (max-width: 749px) {
    .riskr-mission {
      padding-block: 72px;
    }

    .riskr-mission__inner {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .riskr-mission__col-label {
      padding-top: 0;
    }
  }
</style>

{% schema %}
{
  "name": "Riskr Mission",
  "tag": "section",
  "class": "riskr-mission-section",
  "settings": [],
  "presets": [
    {
      "name": "Riskr Mission"
    }
  ]
}
{% endschema %}
